---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — brainlodestones.com"
  description="The page you were looking for could not be found. Explore brainlodestones.com — the premium plural domain for TMS networks and brain health platforms."
  noindex={true}
>
  <main class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center max-w-lg">
      <div
        class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-white/5 border border-slate-800 mb-8"
      >
        <span class="text-4xl font-display text-slate-500">404</span>
      </div>
      <h1 class="text-3xl font-semibold tracking-tight mb-4">Page not found</h1>
      <p class="text-slate-400 mb-8">
        The page you were looking for doesn't exist or has been moved. The domain
        brainlodestones.com is available for acquisition.
      </p>
      <a
        href="/"
        class="inline-flex items-center justify-center px-8 py-3.5 rounded-2xl bg-white text-slate-950 font-semibold hover:bg-slate-100 transition-all"
      >
        Return Home
      </a>
    </div>
  </main>
</BaseLayout>
