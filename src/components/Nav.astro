---
import { acquisitionMailto } from '../lib/constants';
---

<nav
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-slate-800 bg-slate-950/95 backdrop-blur-lg"
>
  <div class="max-w-screen-2xl mx-auto px-6">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-x-2.5" aria-label="brainlodestones.com home">
        <div
          class="w-9 h-9 rounded-xl bg-gradient-to-br from-teal-400 to-cyan-500 flex items-center justify-center shadow-inner"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5 text-slate-950"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2.5"
              d="M9.663 17.684a4.002 4.002 0 01-7.326 0M9.663 17.684L12 21m-2.337-3.316l.663-1.316M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a4.002 4.002 0 01-7.326 0"
            />
          </svg>
        </div>
        <div>
          <span class="font-display text-2xl font-semibold tracking-tighter">brain</span>
          <span class="font-display text-2xl font-semibold tracking-tighter text-teal-400">lodestones</span>
          <span class="font-mono text-[10px] text-teal-400/70 align-super ml-0.5">.com</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-x-9 text-sm font-medium">
        <a href="#opportunity" class="nav-link text-slate-400 hover:text-teal-400"
          >The Opportunity</a
        >
        <a href="#science" class="nav-link text-slate-400 hover:text-teal-400"
          >The Science</a
        >
        <a href="#why" class="nav-link text-slate-400 hover:text-teal-400"
          >Why This Domain</a
        >
        <a href="#perfect-for" class="nav-link text-slate-400 hover:text-teal-400">Perfect For</a>
      </div>

      <!-- CTA Buttons -->
      <div class="flex items-center gap-x-3">
        <a
          href="#acquire"
          class="hidden sm:inline-flex items-center justify-center px-5 py-2.5 text-sm font-semibold rounded-2xl bg-white text-slate-900 hover:bg-slate-100 active:scale-[0.985] transition-all shadow-sm"
        >
          Acquire Domain
        </a>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden w-10 h-10 flex items-center justify-center text-slate-400 hover:text-white hover:bg-slate-900 rounded-2xl transition-colors"
          aria-label="Toggle menu"
        >
          <svg
            id="menu-icon"
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"
            />
          </svg>
        </button>
      </div>
    </div>
  </div>
</nav>

<!-- Mobile Menu -->
<div
  id="mobile-menu"
  class="hidden md:hidden fixed inset-0 z-40 bg-slate-950 pt-20"
>
  <div class="px-6 py-8 flex flex-col gap-y-6 text-lg font-medium">
    <a href="#opportunity" class="mobile-nav-link py-2 text-slate-400 hover:text-white">The Opportunity</a>
    <a href="#science" class="mobile-nav-link py-2 text-slate-400 hover:text-white">The Science</a>
    <a href="#why" class="mobile-nav-link py-2 text-slate-400 hover:text-white">Why This Domain</a>
    <a href="#perfect-for" class="mobile-nav-link py-2 text-slate-400 hover:text-white">Perfect For</a>
    <div class="pt-4 border-t border-slate-800">
      <a
        href="#acquire"
        class="mobile-nav-link block w-full text-center py-3.5 rounded-2xl bg-white text-slate-900 font-semibold"
      >
        Acquire brainlodestones.com
      </a>
    </div>
  </div>
</div>

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const icon = document.getElementById('menu-icon');
    const links = document.querySelectorAll('.mobile-nav-link');

    btn?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
      if (icon) {
        if (!menu?.classList.contains('hidden')) {
          icon.innerHTML =
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6h12v12" />';
        } else {
          icon.innerHTML =
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />';
        }
      }
    });

    links.forEach((link) => {
      link.addEventListener('click', () => {
        menu?.classList.add('hidden');
        if (icon) {
          icon.innerHTML =
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />';
        }
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
        menu?.classList.add('hidden');
      }
    });
  }

  function initSmoothScroll() {
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener('click', function (e) {
        const targetId = this.getAttribute('href')?.substring(1);
        const target = targetId ? document.getElementById(targetId) : null;
        if (target) {
          e.preventDefault();
          const offset = 80;
          const bodyRect = document.body.getBoundingClientRect().top;
          const elementPosition = target.getBoundingClientRect().top;
          const offsetPosition = elementPosition - bodyRect - offset;
          window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
        }
      });
    });
  }

  initMobileMenu();
  initSmoothScroll();
</script>
